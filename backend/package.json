{
  "name": "generic-saas-backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p ../shared/tsconfig.json && tsc",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:generate-from-metadata": "tsx scripts/generate-schema-from-metadata.ts",
    "db:generate-from-metadata-temp": "tsx scripts/generate-schema-from-metadata.ts --temp-dir --dialect=mysql",
    "db:generate-temp": "drizzle-kit generate --config=./drizzle-temp/drizzle.config.ts",
    "db:generate-temp-noninteractive": "tsx scripts/generate-migrations-noninteractive.ts",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:fix-pending-migrations": "tsx scripts/fix-pending-migrations.ts",
    "db:ensure-tables": "tsx scripts/ensure-tables.ts",
    "db:sync-drops": "tsx scripts/sync-drops.ts",
    "db:deploy": "pnpm exec tsc -p ../shared/tsconfig.json && pnpm run db:validate-metadata && pnpm run db:generate-from-metadata-temp && pnpm run db:generate-temp-noninteractive && pnpm run db:fix-pending-migrations && pnpm run db:migrate && pnpm run db:ensure-tables && pnpm run db:verify-schema && pnpm run db:sync-drops && cp drizzle-temp/db/schema.ts src/db/schema.ts && cp drizzle-temp/routes/entity-registry.generated.ts src/routes/entity-registry.generated.ts",
    "db:seed": "tsx src/seed.ts",
    "db:seed-customers": "tsx scripts/seed-customers.ts",
    "db:seed-deploytest": "tsx scripts/seed-deploytest.ts",
    "db:seed-multi-tenant": "tsx scripts/seed-multi-tenant.ts",
    "db:seed-single-tenant": "tsx scripts/seed-single-tenant.ts",
    "db:validate-metadata": "tsx scripts/validate-metadata.ts",
    "db:verify-schema": "tsx scripts/verify-schema.ts",
    "translation-report": "tsx scripts/translation-report.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "bcrypt": "^5.1.1",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.36.0",
    "hono": "^4.6.0",
    "jose": "^5.9.0",
    "mysql2": "^3.11.0",
    "nodemailer": "^8.0.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/nodemailer": "^7.0.10",
    "drizzle-kit": "^0.28.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}